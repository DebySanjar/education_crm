rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    // Helper functions
    // ═══════════════════════════════════════════════════════════

    // Foydalanuvchi login qilganmi
    function isAuth() {
      return request.auth != null;
    }

    // Super admin — to'liq huquq
    function isSuperAdmin() {
      return isAuth() && request.auth.token.email == 'bu@boss.uz';
    }

    // Istalgan admin (super yoki limited)
    function isAnyAdmin() {
      return isAuth() && (
        request.auth.token.email == 'bu@boss.uz' ||
        request.auth.token.email == 'bu@admin.uz'
      );
    }

    // ═══════════════════════════════════════════════════════════
    // Students
    // ═══════════════════════════════════════════════════════════
    match /students/{studentId} {
      allow read:   if isAnyAdmin();
      allow create: if isAnyAdmin();
      allow update: if isAnyAdmin();
      allow delete: if isSuperAdmin();   // faqat super admin o'chira oladi
    }

    // ═══════════════════════════════════════════════════════════
    // Payments
    // ═══════════════════════════════════════════════════════════
    match /payments/{paymentId} {
      allow read:          if isAnyAdmin();
      allow create:        if isAnyAdmin();
      allow update:        if isAnyAdmin();
      allow delete:        if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // Attendance
    // ═══════════════════════════════════════════════════════════
    match /attendance/{date} {
      allow read:   if isAnyAdmin();
      allow write:  if isAnyAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // Expenses
    // ═══════════════════════════════════════════════════════════
    match /expenses/{expenseId} {
      allow read:   if isAnyAdmin();
      allow create: if isAnyAdmin();
      allow update: if isAnyAdmin();
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // Groups
    // ═══════════════════════════════════════════════════════════
    match /groups/{groupId} {
      allow read:   if isAnyAdmin();
      allow create: if isSuperAdmin();   // guruh qo'shish faqat super admin
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // Balance
    // ═══════════════════════════════════════════════════════════
    match /balance/{balanceId} {
      allow read:  if isAnyAdmin();
      allow write: if isAnyAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // Boshqa barcha documentlar — ruxsat yo'q
    // ═══════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
